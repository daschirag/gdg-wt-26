---
import MainLayout from "../Layouts/MainLayout.astro";
---

<MainLayout>
  <!-- TopAppBar -->
  <header class="fixed top-0 left-0 right-0 z-50 max-w-7xl mx-auto mt-4 px-4">
    <div class="neu-surface rounded-full bg-surface flex items-center justify-between px-6 py-3 gap-4">
      <!-- Logo -->
      <div class="flex items-center gap-2.5 shrink-0">
        <span class="material-symbols-outlined text-primary text-xl">database</span>
        <span class="text-lg font-black text-on-surface font-['Space_Grotesk'] tracking-tight">AQE</span>
      </div>
      <!-- Tab nav -->
      <nav class="hidden md:flex items-center gap-1 neu-pressed rounded-full px-2 py-1.5">
        <button data-tab="overview"  class="tab-btn px-4 py-1 rounded-full text-sm font-bold font-['Space_Grotesk'] tracking-tight transition-all bg-black text-white shadow-md">Overview</button>
        <button data-tab="benchmark" class="tab-btn px-4 py-1 rounded-full text-sm font-bold font-['Space_Grotesk'] tracking-tight transition-all text-slate-400 hover:text-on-surface">Benchmark</button>
        <button data-tab="live"      class="tab-btn px-4 py-1 rounded-full text-sm font-bold font-['Space_Grotesk'] tracking-tight transition-all text-slate-400 hover:text-on-surface">Live</button>
        <button data-tab="advanced"  class="tab-btn px-4 py-1 rounded-full text-sm font-bold font-['Space_Grotesk'] tracking-tight transition-all text-slate-400 hover:text-on-surface">Advanced</button>
        <button data-tab="docs"      class="tab-btn px-4 py-1 rounded-full text-sm font-bold font-['Space_Grotesk'] tracking-tight transition-all text-slate-400 hover:text-on-surface">Docs</button>
      </nav>
      <!-- Status badge -->
      <div class="shrink-0">
        <span id="nav-live-badge" class="px-4 py-1 rounded-full neu-pressed text-[#2c50cd] text-xs font-bold tracking-widest">LIVE</span>
      </div>
    </div>
  </header>

  <main class="max-w-7xl mx-auto px-6 pt-32 pb-40">

    <!-- ================================================================ -->
    <!-- TAB: OVERVIEW                                                     -->
    <!-- ================================================================ -->
    <section id="tab-overview">
    <!-- Hero Summary Card -->
    <div class="mb-16">
      <div class="neu-surface rounded-xl p-10 md:p-16 flex flex-col md:flex-row items-center gap-12 bg-surface">
        <div class="flex-1 space-y-6">
          <span class="inline-block px-4 py-1 rounded-full bg-surface-container-high text-primary font-bold text-xs uppercase tracking-[0.2em]">Engine Status: Operational</span>
          <h2 class="text-4xl md:text-6xl font-headline font-bold text-on-surface leading-tight tracking-tighter">
            AQE — Storage-Aware <span class="text-primary text-glow">Approximate</span> Query Engine
          </h2>
          <p class="text-on-surface-variant text-lg max-w-xl leading-relaxed">
            A high-performance Rust-based core designed for low-latency analytics through intelligent data sampling and multi-modal pipeline execution.
          </p>
        </div>
        <div class="w-full md:w-1/3 aspect-square rounded-xl overflow-hidden neu-surface p-4 bg-surface-container">
          <div class="w-full h-full rounded-lg overflow-hidden relative">
            <img alt="Data Architecture" class="w-full h-full object-cover grayscale opacity-80" src="https://lh3.googleusercontent.com/aida-public/AB6AXuDiYJnkOtLuRxnnJ0lt67rfWdR3H9BOWdKkrzp9JvpbqFdAVnyeY23LsH7OnmsNLgLEoYn5h-3hElxmly4vLwginLOEH9jxBWV-KCkfYGzpipmeuQ0UELwWecti7AftPaiJicbzNMijKYljJzGBAkyOzETJOptRGgtcNpAPEW_HNHsbOv6DUVT1iFbKRo3s_LFRx43FKnQSECKzGm4HFKZ8WMlTbre2IJo5EIVupqc14G1qvVT9u_a2BCuoJA47jjBBMoIIGWC6WFVy"/>
            <div class="absolute inset-0 bg-primary/10 mix-blend-overlay"></div>
          </div>
        </div>
      </div>
    </div>

    <!-- Bento Grid: Architecture & Config -->
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-10">
      <!-- Architecture Overview (2 Columns Wide) -->
      <div class="lg:col-span-2 space-y-8">
        <h3 class="text-2xl font-headline font-bold tracking-tight flex items-center gap-3 px-2">
          <span class="w-8 h-[2px] bg-primary"></span>
          Architecture Overview
        </h3>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
          <!-- Storage Layer -->
          <div class="neu-pressed rounded-lg p-8 bg-surface-container-low border border-white/40 flex flex-col justify-between min-h-[220px]">
            <div>
              <span class="material-symbols-outlined text-primary mb-4 block">storage</span>
              <h4 class="font-headline font-bold text-on-surface mb-2">Storage Layer</h4>
            </div>
            <p class="text-on-surface-variant text-sm leading-relaxed">
              LSM-tree with memtable, SSTables, and columnar segments.
            </p>
          </div>
          <!-- Query Layer -->
          <div class="neu-pressed rounded-lg p-8 bg-surface-container-low border border-white/40 flex flex-col justify-between min-h-[220px]">
            <div>
              <span class="material-symbols-outlined text-primary mb-4 block">terminal</span>
              <h4 class="font-headline font-bold text-on-surface mb-2">Query Layer</h4>
            </div>
            <p class="text-on-surface-variant text-sm leading-relaxed">
              SQL parser, planner, and pipelines (row, columnar, mixed).
            </p>
          </div>
          <!-- AQP Layer -->
          <div class="neu-pressed rounded-lg p-8 bg-surface-container-low border border-white/40 flex flex-col justify-between min-h-[220px]">
            <div>
              <span class="material-symbols-outlined text-primary mb-4 block">analytics</span>
              <h4 class="font-headline font-bold text-on-surface mb-2">AQP Layer</h4>
            </div>
            <p class="text-on-surface-variant text-sm leading-relaxed">
              Sampling, estimators, and accuracy control (0.70 target).
            </p>
          </div>
        </div>
      </div>

      <!-- Config Facade -->
      <div class="space-y-8">
        <h3 class="text-2xl font-headline font-bold tracking-tight px-2">Quick Config</h3>
        <div class="neu-pressed rounded-lg p-8 bg-surface-container-high flex flex-col gap-6">
          <!-- accuracy_target -->
          <div class="flex flex-col gap-2">
            <div class="flex justify-between items-center">
              <label class="text-sm font-medium text-on-surface-variant">Accuracy Target</label>
              <span id="facade-accuracy-val" class="text-lg font-headline font-bold text-primary">0.70</span>
            </div>
            <input id="facade-accuracy" type="range" min="0.1" max="1.0" step="0.05" value="0.70"
              class="w-full accent-primary neu-pressed rounded-full h-2 cursor-pointer" />
          </div>
          <!-- k -->
          <div class="flex flex-col gap-2">
            <div class="flex justify-between items-center">
              <label class="text-sm font-medium text-on-surface-variant">Confidence k</label>
              <span id="facade-k-val" class="text-lg font-headline font-bold text-primary">2.0</span>
            </div>
            <input id="facade-k" type="range" min="0.5" max="10.0" step="0.5" value="2.0"
              class="w-full accent-primary neu-pressed rounded-full h-2 cursor-pointer" />
          </div>
          <!-- memtable_row_limit -->
          <div class="flex flex-col gap-2">
            <div class="flex justify-between items-center">
              <label class="text-sm font-medium text-on-surface-variant">Memtable Row Limit</label>
              <span id="facade-memrows-val" class="text-lg font-headline font-bold text-on-surface">1048576</span>
            </div>
            <input id="facade-memrows" type="range" min="1000" max="2000000" step="1000" value="1048576"
              class="w-full accent-primary neu-pressed rounded-full h-2 cursor-pointer" />
          </div>
          <div class="flex items-center gap-3 mt-2">
            <button id="facade-apply-btn"
              class="bg-black text-white px-6 py-2.5 rounded-full font-bold text-sm shadow-lg shadow-black/40 active:scale-95 transition-all hover:bg-slate-900">
              Apply
            </button>
            <span id="facade-status" class="text-xs text-slate-500"></span>
          </div>
        </div>
      </div>
    </div>
    </section><!-- /tab-overview -->

    <!-- ================================================================ -->
    <!-- TAB: BENCHMARK                                                   -->
    <!-- ================================================================ -->
    <section id="tab-benchmark" class="hidden">
    <section class="mt-4" id="benchmark">
      <h3 class="text-2xl font-headline font-bold tracking-tight flex items-center gap-3 px-2 mb-8">
        <span class="w-8 h-[2px] bg-primary"></span>
        Benchmark
        <span class="ml-2 px-3 py-0.5 rounded-full bg-surface-container-high text-primary text-xs font-bold tracking-widest uppercase">AQE vs SQLite</span>
      </h3>

      <!-- Init controls -->
      <div class="neu-surface rounded-xl p-8 bg-surface flex flex-col gap-6 mb-8">
        <div class="flex items-center gap-3 mb-1">
          <span class="material-symbols-outlined text-primary">settings</span>
          <span class="font-headline font-bold text-on-surface">Engine Setup</span>
          <span id="init-status" class="ml-auto text-xs text-slate-500"></span>
        </div>
        <div class="flex flex-wrap gap-4">
          <button id="btn-gen-dataset"
            class="flex items-center gap-2 px-6 py-3 rounded-full font-bold text-sm neu-pressed bg-surface-container-low text-on-surface active:scale-95 transition-all hover:bg-surface-container">
            <span class="material-symbols-outlined text-base">dataset</span>
            Generate Dataset
          </button>
          <button id="btn-init-sqlite"
            class="flex items-center gap-2 px-6 py-3 rounded-full font-bold text-sm neu-pressed bg-surface-container-low text-on-surface active:scale-95 transition-all hover:bg-surface-container">
            <span class="material-symbols-outlined text-base">database</span>
            Init SQLite
          </button>
          <button id="btn-init-aqe"
            class="flex items-center gap-2 px-6 py-3 rounded-full font-bold text-sm neu-pressed bg-surface-container-low text-on-surface active:scale-95 transition-all hover:bg-surface-container">
            <span class="material-symbols-outlined text-base">bolt</span>
            Load AQE
          </button>
          <div id="init-spinner" class="hidden flex items-center gap-2 text-sm text-slate-500">
            <span class="material-symbols-outlined animate-spin text-primary text-base">autorenew</span>
            <span id="init-spinner-label">Working…</span>
          </div>
        </div>
        <div id="init-log" class="hidden neu-pressed rounded-lg px-4 py-3 text-xs font-mono text-slate-600 bg-surface-container-high whitespace-pre-wrap max-h-28 overflow-auto"></div>
      </div>

      <!-- Query runner -->
      <div class="neu-surface rounded-xl p-8 bg-surface flex flex-col gap-6">
        <!-- Query input row -->
        <div class="flex flex-col md:flex-row gap-4 items-start md:items-end">
          <div class="flex-1 flex flex-col gap-2">
            <label class="text-[10px] uppercase tracking-widest font-bold text-slate-500" for="bench-select">Benchmark Query</label>
            <div class="neu-pressed rounded-lg overflow-hidden">
              <select id="bench-select" class="w-full bg-transparent px-4 py-3 text-sm font-medium text-on-surface outline-none cursor-pointer">
                <option value="">— select a query —</option>
              </select>
            </div>
          </div>
          <div class="flex-1 flex flex-col gap-2">
            <label class="text-[10px] uppercase tracking-widest font-bold text-slate-500" for="sql-input">SQL</label>
            <div class="neu-pressed rounded-lg overflow-hidden">
              <input id="sql-input" type="text" placeholder="SELECT COUNT(*) FROM logs"
                class="w-full bg-transparent px-4 py-3 text-sm font-mono text-on-surface outline-none placeholder:text-slate-400" />
            </div>
          </div>
          <button id="run-btn"
            class="shrink-0 bg-black text-white px-8 py-3 rounded-full font-bold shadow-lg shadow-black/40 active:scale-95 transition-all hover:bg-slate-900 flex items-center gap-2">
            <span class="material-symbols-outlined text-base">play_arrow</span>
            Run
          </button>
          <button id="run-all-btn"
            class="shrink-0 neu-pressed border-0 text-slate-600 px-6 py-3 rounded-full font-bold active:scale-95 transition-all flex items-center gap-2">
            <span class="material-symbols-outlined text-base">playlist_play</span>
            Run All
          </button>
          <button id="load-cached-btn"
            class="shrink-0 neu-pressed border-0 text-slate-600 px-6 py-3 rounded-full font-bold active:scale-95 transition-all flex items-center gap-2">
            <span class="material-symbols-outlined text-base">history</span>
            Load Cached
          </button>
        </div>

        <!-- Loading indicator -->
        <div id="lab-loading" class="hidden items-center gap-3 text-sm text-slate-500">
          <span class="material-symbols-outlined animate-spin text-primary">autorenew</span>
          Running query…
        </div>

        <!-- Side-by-side single-query results -->
        <div id="lab-results" class="hidden grid-cols-1 md:grid-cols-2 gap-6 mt-2">
          <!-- AQE panel -->
          <div class="neu-pressed rounded-xl p-6 bg-surface-container-low flex flex-col gap-4">
            <div class="flex items-center justify-between">
              <div class="flex items-center gap-2">
                <span class="material-symbols-outlined text-primary text-lg">bolt</span>
                <span class="font-headline font-bold text-on-surface">AQE</span>
              </div>
              <span id="aqe-confidence" class="px-3 py-0.5 rounded-full text-[10px] font-bold tracking-widest uppercase bg-surface-container-high text-primary"></span>
            </div>
            <div id="aqe-result" class="text-3xl font-headline font-bold text-on-surface tracking-tighter break-all"></div>
            <div class="grid grid-cols-2 gap-3 mt-2">
              <div class="neu-surface rounded-lg p-3 bg-surface text-center">
                <div class="text-[10px] uppercase tracking-widest text-slate-500 mb-1">Time</div>
                <div id="aqe-time" class="text-lg font-headline font-bold text-primary"></div>
              </div>
              <div class="neu-surface rounded-lg p-3 bg-surface text-center">
                <div class="text-[10px] uppercase tracking-widest text-slate-500 mb-1">Rows Scanned</div>
                <div id="aqe-rows" class="text-lg font-headline font-bold text-on-surface"></div>
              </div>
            </div>
            <div id="aqe-warnings" class="hidden text-xs text-amber-600 bg-amber-50 rounded-lg px-3 py-2 mt-1"></div>
          </div>
          <!-- SQLite panel -->
          <div class="neu-pressed rounded-xl p-6 bg-surface-container-low flex flex-col gap-4">
            <div class="flex items-center gap-2">
              <span class="material-symbols-outlined text-slate-500 text-lg">database</span>
              <span class="font-headline font-bold text-on-surface">SQLite</span>
            </div>
            <div id="sqlite-result" class="text-3xl font-headline font-bold text-on-surface tracking-tighter break-all"></div>
            <div class="neu-surface rounded-lg p-3 bg-surface text-center mt-2">
              <div class="text-[10px] uppercase tracking-widest text-slate-500 mb-1">Time</div>
              <div id="sqlite-time" class="text-lg font-headline font-bold text-on-surface"></div>
            </div>
          </div>
        </div>

        <!-- Speedup badge -->
        <div id="speedup-badge" class="hidden justify-center mt-2">
          <span id="speedup-text" class="px-6 py-2 rounded-full font-bold text-sm shadow-md"></span>
        </div>

        <!-- Run-all / cached results table -->
        <div id="bench-table-wrap" class="hidden mt-4">
          <div class="flex items-center justify-between mb-4">
            <span class="text-[10px] uppercase tracking-widest font-bold text-slate-500" id="bench-table-label">Benchmark Results</span>
            <!-- Category filter pills -->
            <div id="cat-pills" class="flex flex-wrap gap-2"></div>
          </div>
          <div class="neu-pressed rounded-xl overflow-x-auto">
            <table class="w-full text-sm">
              <thead>
                <tr class="border-b border-white/30 text-[10px] uppercase tracking-widest text-slate-500">
                  <th class="text-left px-4 py-3">Label</th>
                  <th class="text-left px-4 py-3 hidden md:table-cell">Category</th>
                  <th class="text-right px-4 py-3">AQE ms</th>
                  <th class="text-right px-4 py-3">SQLite ms</th>
                  <th class="text-right px-4 py-3">Speedup</th>
                  <th class="text-right px-4 py-3 hidden md:table-cell">Strategy</th>
                </tr>
              </thead>
              <tbody id="bench-tbody" class="divide-y divide-white/20"></tbody>
            </table>
          </div>
        </div>
      </div>
    </section>
    </section><!-- /tab-benchmark -->

    <!-- ================================================================ -->
    <!-- TAB: LIVE                                                         -->
    <!-- ================================================================ -->
    <section id="tab-live" class="hidden">
    <!-- Live Ingestion Section -->
    <section class="mt-4" id="live">
      <h3 class="text-2xl font-headline font-bold tracking-tight flex items-center gap-3 px-2 mb-8">
        <span class="w-8 h-[2px] bg-primary"></span>
        Live Ingestion
        <span id="live-badge" class="ml-2 px-3 py-0.5 rounded-full bg-surface-container-high text-slate-500 text-xs font-bold tracking-widest uppercase">Idle</span>
      </h3>
      <div class="neu-surface rounded-xl p-8 bg-surface flex flex-col gap-6">
        <!-- Controls row -->
        <div class="flex flex-wrap items-center gap-4">
          <button id="live-start-btn"
            class="flex items-center gap-2 px-6 py-3 rounded-full font-bold text-sm bg-black text-white shadow-lg shadow-black/40 active:scale-95 transition-all hover:bg-slate-900">
            <span class="material-symbols-outlined text-base">play_arrow</span>
            Start
          </button>
          <button id="live-stop-btn"
            class="flex items-center gap-2 px-6 py-3 rounded-full font-bold text-sm neu-pressed bg-surface-container-low text-on-surface active:scale-95 transition-all">
            <span class="material-symbols-outlined text-base">stop</span>
            Stop
          </button>
          <div class="flex gap-6 ml-4">
            <div class="text-center">
              <div class="text-[10px] uppercase tracking-widest text-slate-500 mb-1">Rows/sec</div>
              <div id="live-rate" class="text-2xl font-headline font-bold text-primary">—</div>
            </div>
            <div class="text-center">
              <div class="text-[10px] uppercase tracking-widest text-slate-500 mb-1">Total Inserted</div>
              <div id="live-total" class="text-2xl font-headline font-bold text-on-surface">—</div>
            </div>
            <div class="text-center">
              <div class="text-[10px] uppercase tracking-widest text-slate-500 mb-1">Reservoir Size</div>
              <div id="live-reservoir" class="text-2xl font-headline font-bold text-on-surface">—</div>
            </div>
          </div>
        </div>
        <!-- Query on ingested data -->
        <div class="border-t border-white/20 pt-6 flex flex-col gap-4">
          <span class="text-[10px] uppercase tracking-widest font-bold text-slate-500">Query Ingested Data</span>
          <div class="flex flex-col md:flex-row gap-3 items-start md:items-end">
            <div class="neu-pressed rounded-lg overflow-hidden flex-shrink-0">
              <select id="live-query-select" class="bg-transparent px-4 py-3 text-sm font-medium text-on-surface outline-none cursor-pointer">
                <optgroup label="SIMPLE">
                  <option value="SELECT COUNT(*) FROM logs">COUNT all</option>
                  <option value="SELECT SUM(level) FROM logs">SUM level</option>
                  <option value="SELECT AVG(level) FROM logs">AVG level</option>
                </optgroup>
                <optgroup label="EQUALITY FILTER">
                  <option value="SELECT COUNT(*) FROM logs WHERE status = 0">COUNT status=0</option>
                  <option value="SELECT COUNT(*) FROM logs WHERE status = 1">COUNT status=1</option>
                  <option value="SELECT COUNT(*) FROM logs WHERE country = 2">COUNT country=2</option>
                  <option value="SELECT SUM(level) FROM logs WHERE status = 0">SUM level WHERE status=0</option>
                </optgroup>
                <optgroup label="BITMAP — AND / OR / NOT">
                  <option value="SELECT COUNT(*) FROM logs WHERE status = 0 AND country = 1">COUNT AND</option>
                  <option value="SELECT COUNT(*) FROM logs WHERE status = 0 AND country = 2">COUNT AND (alt)</option>
                  <option value="SELECT SUM(level) FROM logs WHERE status = 0 AND country = 1">SUM AND</option>
                  <option value="SELECT COUNT(*) FROM logs WHERE status = 0 OR country = 1">COUNT OR</option>
                  <option value="SELECT AVG(level) FROM logs WHERE status = 0 OR country = 1">AVG OR</option>
                  <option value="SELECT COUNT(*) FROM logs WHERE NOT status = 1">COUNT NOT</option>
                  <option value="SELECT SUM(level) FROM logs WHERE NOT status = 2">SUM NOT</option>
                </optgroup>
                <optgroup label="GROUP BY">
                  <option value="SELECT COUNT(*) FROM logs GROUP BY country">COUNT GROUP BY country</option>
                  <option value="SELECT COUNT(*) FROM logs GROUP BY status">COUNT GROUP BY status</option>
                  <option value="SELECT SUM(level) FROM logs GROUP BY status">SUM level GROUP BY status</option>
                  <option value="SELECT AVG(level) FROM logs GROUP BY country">AVG level GROUP BY country</option>
                </optgroup>
                <optgroup label="BITMAP + GROUP BY">
                  <option value="SELECT COUNT(*) FROM logs WHERE status = 0 OR country = 1 GROUP BY country">COUNT OR GROUP BY country</option>
                  <option value="SELECT SUM(level) FROM logs WHERE NOT status = 2 GROUP BY status">SUM NOT GROUP BY status</option>
                  <option value="SELECT COUNT(*) FROM logs WHERE status = 0 AND country = 1 GROUP BY country">COUNT AND GROUP BY country</option>
                </optgroup>
                <option value="custom">— custom SQL —</option>
              </select>
            </div>
            <div class="neu-pressed rounded-lg overflow-hidden flex-1">
              <input id="live-sql-input" type="text" placeholder="SELECT COUNT(*) FROM logs"
                class="w-full bg-transparent px-4 py-3 text-sm font-mono text-on-surface outline-none placeholder:text-slate-400" />
            </div>
            <button id="live-run-btn"
              class="shrink-0 bg-black text-white px-6 py-3 rounded-full font-bold text-sm shadow-lg shadow-black/40 active:scale-95 transition-all hover:bg-slate-900 flex items-center gap-2">
              <span class="material-symbols-outlined text-base">bolt</span>
              Run
            </button>
          </div>
          <div id="live-query-result" class="hidden neu-pressed rounded-xl p-5 bg-surface-container-low flex flex-col gap-3">
            <div class="flex items-center justify-between">
              <span id="live-qr-value" class="text-2xl font-headline font-bold text-on-surface tracking-tighter break-all"></span>
              <span id="live-qr-confidence" class="px-3 py-0.5 rounded-full text-[10px] font-bold tracking-widest uppercase bg-surface-container-high text-primary"></span>
            </div>
            <div class="flex gap-4 text-xs text-slate-500">
              <span id="live-qr-time"></span>
              <span id="live-qr-rows"></span>
              <span id="live-qr-path"></span>
            </div>
            <div id="live-qr-groups" class="hidden overflow-x-auto">
              <table class="w-full text-xs">
                <thead><tr class="border-b border-white/30 text-[10px] uppercase tracking-widest text-slate-500">
                  <th class="text-left px-3 py-2">Group</th>
                  <th class="text-right px-3 py-2">Value</th>
                  <th class="text-right px-3 py-2">Confidence</th>
                </tr></thead>
                <tbody id="live-qr-groups-tbody" class="divide-y divide-white/20 font-mono"></tbody>
              </table>
            </div>
            <div id="live-qr-warnings" class="hidden text-xs text-amber-600 bg-amber-50 rounded-lg px-3 py-2"></div>
          </div>
        </div>

        <!-- Sample table -->
        <div class="neu-pressed rounded-xl overflow-x-auto">
          <table class="w-full text-xs">
            <thead>
              <tr class="border-b border-white/30 text-[10px] uppercase tracking-widest text-slate-500">
                <th class="text-right px-4 py-3">user_id</th>
                <th class="text-right px-4 py-3">status</th>
                <th class="text-right px-4 py-3">country</th>
                <th class="text-right px-4 py-3">timestamp</th>
                <th class="text-right px-4 py-3">level</th>
              </tr>
            </thead>
